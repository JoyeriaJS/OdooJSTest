<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- HEADER (EL QUE YA FUNCIONA) -->
    <t t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <xpath expr="//div[contains(@class,'cashier')]" position="replace">

            <div class="cashier">

                <t t-if="props.data.vendedora_name">
                    <div>
                        Atendido por:
                        <t t-esc="props.data.vendedora_name"/>
                    </div>
                </t>

                <t t-else="">
                    <div>
                        Atendido por:
                        <t t-esc="props.data.cashier"/>
                    </div>
                </t>

            </div>

        </xpath>

    </t>


    <!-- EXTENSIÓN SEGURA DE CADA LÍNEA -->
    <t t-inherit="point_of_sale.Orderline"
       t-inherit-mode="extension">

        <!-- Insertamos al final sin depender de estructura interna -->
        <xpath expr="." position="inside">

            <t t-if="props.line and props.line.gramos">
                <div style="font-size:12px; margin-left:15px;">
                    <strong>Gramos:</strong>
                    <t t-esc="props.line.gramos"/>
                </div>
            </t>

            <t t-if="props.line and props.line.descripcion_personalizada">
                <div style="font-size:12px; margin-left:15px;">
                    <strong>Detalle:</strong>
                    <t t-esc="props.line.descripcion_personalizada"/>
                </div>
            </t>

        </xpath>

    </t>

</templates>