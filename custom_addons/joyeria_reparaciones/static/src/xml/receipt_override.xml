<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <xpath expr="//div[contains(@class,'cashier')]" position="replace">

            <div class="cashier">
                <t t-if="order.get_vendedora_name()">
                    Atendido por:
                    <t t-esc="order.get_vendedora_name()"/>
                </t>
                <t t-else="">
                    Atendido por:
                    <t t-esc="order.get_cashier().name"/>
                </t>
            </div>

        </xpath>

    </t>

</templates>