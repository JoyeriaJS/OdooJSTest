<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <xpath expr="//div[contains(@class,'cashier')]" position="after">

            <t t-if="props.data.vendedora_name">
                <div class="vendedora-line">
                    Atendido por:
                    <t t-esc="props.data.vendedora_name"/>
                </div>
            </t>

        </xpath>

    </t>

</templates>