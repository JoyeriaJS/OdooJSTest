<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- ============================= -->
    <!-- HEADER - VENDEDORA (YA TENIAS) -->
    <!-- ============================= -->
    <t t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <!-- Reemplazamos completamente el cashier -->
        <xpath expr="//div[contains(@class,'cashier')]" position="replace">

            <div class="cashier">

                <t t-if="props.data.vendedora_name">
                    <div>
                        Atendido por:
                        <t t-esc="props.data.vendedora_name"/>
                    </div>
                </t>

                <t t-else="">
                    <div>
                        Atendido por:
                        <t t-esc="props.data.cashier"/>
                    </div>
                </t>

            </div>

        </xpath>

    </t>


    <!-- ====================================== -->
    <!-- AGREGAR GRAMOS Y DESCRIPCION AL TICKET -->
    <!-- ====================================== -->
    <t t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <xpath expr="//t[@t-foreach='receipt.orderlines']" position="inside">

            <t t-if="line.gramos">
                <div style="margin-left:10px; font-size:12px;">
                    <strong>Gramos:</strong>
                    <t t-esc="line.gramos"/>
                </div>
            </t>

            <t t-if="line.descripcion_personalizada">
                <div style="margin-left:10px; font-size:12px;">
                    <strong>Detalle:</strong>
                    <t t-esc="line.descripcion_personalizada"/>
                </div>
            </t>

        </xpath>

    </t>

</templates>