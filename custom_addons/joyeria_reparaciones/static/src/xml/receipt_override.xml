<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- HEADER (el que ya funciona) -->
    <t t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <xpath expr="//div[contains(@class,'cashier')]" position="replace">
            <div class="cashier">

                <t t-if="props.data.vendedora_name">
                    <div>
                        Atendido por:
                        <t t-esc="props.data.vendedora_name"/>
                    </div>
                </t>

                <t t-else="">
                    <div>
                        Atendido por:
                        <t t-esc="props.data.cashier"/>
                    </div>
                </t>

            </div>
        </xpath>

    </t>


    <!-- EXTENSION SEGURA SOBRE RECEIPT -->
    <t t-inherit="point_of_sale.Receipt"
       t-inherit-mode="extension">

        <xpath expr="//t[@t-foreach='props.data.orderlines']" position="inside">

            <t t-if="line.gramos">
                <div style="font-size:12px; margin-left:15px;">
                    <strong>Gramos:</strong>
                    <t t-esc="line.gramos"/>
                </div>
            </t>

            <t t-if="line.descripcion_personalizada">
                <div style="font-size:12px; margin-left:15px;">
                    <strong>Detalle:</strong>
                    <t t-esc="line.descripcion_personalizada"/>
                </div>
            </t>

        </xpath>

    </t>

</templates>