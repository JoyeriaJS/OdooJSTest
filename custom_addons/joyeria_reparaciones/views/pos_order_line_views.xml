<odoo>
    <record id="view_pos_order_line_form_inherit_joyeria" model="ir.ui.view">
        <field name="name">pos.order.line.form.joyeria</field>
        <field name="model">pos.order.line</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_line_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='qty']" position="after">
                <field name="gramos"/>
                <field name="descripcion_personalizada"/>
            </xpath>

        </field>
    </record>
</odoo>