<odoo>
    <record id="view_joyeria_reparacion_form" model="ir.ui.view">
        <field name="name">joyeria.reparacion.form</field>
        <field name="model">joyeria.reparacion</field>
        <field name="arch" type="xml">
            <form string="Orden de Reparación">
                <sheet>

                    <group col="2">

                        <!-- Información General -->
                        <group string="Información General" col="2">
                            <field name="name" readonly="1"/>
                            <field name="cliente_id"/>
                            <field name="tipo_cliente"/>
                            <field name="correo_cliente"/>
                            <field name="telefono"/>
                            <field name="direccion_entrega"/>
                            <field name="responsable_id" groups="base.group_system"/>
                            <field name="qr" widget="image" class="oe_avatar" readonly="1"/>
                        </group>

                        <!-- Producto -->
                        <group string="Producto y Servicio" col="2">
                            <field name="servicio"/>
                            <field name="tipo_joya" visibility_condition="servicio == 'reparacion'"/>
                            <field name="modelo"/>
                            <field name="cantidad"/>
                            <field name="metal"/>
                            <field name="n_cm_reparacion" visibility_condition="servicio == 'reparacion'"/>
                            <field name="n_cm_fabricacion" visibility_condition="servicio == 'fabricacion'"/>
                            <field name="peso"/>
                            <field name="peso_valor"/>
                            <field name="solicitud_cliente" colspan="2"/>
                        </group>

                        <!-- SALIDA TALLER -->
                        <group string="🔧 Datos de salida del taller" col="2" groups="base.group_system">

                            <field name="metal_utilizado"/>

                            <!-- PLATA -->
                            <separator string="Configuración Plata"
                                visibility_condition="metal_utilizado == 'plata'"/>

                            <field name="plata_diseno"
                                visibility_condition="metal_utilizado == 'plata'"/>

                            <field name="plata_casting"
                                visibility_condition="metal_utilizado == 'plata'"/>

                            <field name="plata_piedras"
                                visibility_condition="metal_utilizado == 'plata'"/>

                            <field name="plata_cantidad_piedras"
                                visibility_condition="metal_utilizado == 'plata'"/>

                            <field name="plata_total"
                                readonly="1"
                                visibility_condition="metal_utilizado == 'plata'"
                                style="background-color:#fff8b3;font-weight:bold;"/>

                            <!-- ORO AMARILLO -->
                            <separator string="Configuración Oro Amarillo"
                                visibility_condition="metal_utilizado == 'oro_18k_amarillo'"/>

                            <field name="oro_amarillo_diseno"
                                visibility_condition="metal_utilizado == 'oro_18k_amarillo'"/>

                            <field name="oro_amarillo_casting"
                                visibility_condition="metal_utilizado == 'oro_18k_amarillo'"/>

                            <field name="oro_amarillo_piedras"
                                visibility_condition="metal_utilizado == 'oro_18k_amarillo'"/>

                            <field name="oro_amarillo_cantidad_piedras"
                                visibility_condition="metal_utilizado == 'oro_18k_amarillo'"/>

                            <field name="oro_amarillo_total"
                                readonly="1"
                                visibility_condition="metal_utilizado == 'oro_18k_amarillo'"
                                style="background-color:#fff8b3;font-weight:bold;"/>

                            <!-- ORO ROSADO -->
                            <separator string="Configuración Oro Rosado"
                                visibility_condition="metal_utilizado == 'oro_18k_rosado'"/>

                            <field name="oro_rosado_diseno"
                                visibility_condition="metal_utilizado == 'oro_18k_rosado'"/>

                            <field name="oro_rosado_casting"
                                visibility_condition="metal_utilizado == 'oro_18k_rosado'"/>

                            <field name="oro_rosado_piedras"
                                visibility_condition="metal_utilizado == 'oro_18k_rosado'"/>

                            <field name="oro_rosado_cantidad_piedras"
                                visibility_condition="metal_utilizado == 'oro_18k_rosado'"/>

                            <field name="oro_rosado_total"
                                readonly="1"
                                visibility_condition="metal_utilizado == 'oro_18k_rosado'"
                                style="background-color:#fff8b3;font-weight:bold;"/>

                            <!-- OTROS METALES -->
                            <separator string="Configuración Otros Metales"
                                visibility_condition="metal_utilizado not in ['plata','oro_18k_amarillo','oro_18k_rosado']"/>

                            <field name="otros_casting"
                                visibility_condition="metal_utilizado not in ['plata','oro_18k_amarillo','oro_18k_rosado']"/>

                            <field name="otros_piedras"
                                visibility_condition="metal_utilizado not in ['plata','oro_18k_amarillo','oro_18k_rosado']"/>

                            <field name="otros_cantidad_piedras"
                                visibility_condition="metal_utilizado not in ['plata','oro_18k_amarillo','oro_18k_rosado']"/>

                            <field name="otros_total"
                                readonly="1"
                                visibility_condition="metal_utilizado not in ['plata','oro_18k_amarillo','oro_18k_rosado']"
                                style="background-color:#fff8b3;font-weight:bold;"/>

                            <field name="gramos_utilizado"/>

                            <field name="metales_extra"/>

                            <field name="peso_total" readonly="1"
                                style="background-color:#fff8b3;color:#665c00;font-weight:bold;"/>

                            <field name="cobro_interno"/>

                            <field name="hechura"/>

                            <field name="cobros_extras"/>

                            <field name="total_salida_taller" readonly="1"
                                style="background-color:#fff8b3;color:#665c00;font-weight:bold;"/>

                            <field name="clave_firma_manual" password="True"/>
                            <field name="firma_id" readonly="1"/>
                            <field name="fecha_firma" readonly="1"/>

                        </group>

                    </group>

                    <!-- Notas -->
                    <group string="Notas y Comentarios" col="2">
                        <field name="notas"/>
                        <field name="comentarios"/>
                    </group>

                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

</odoo>