<odoo>

    <!-- ======================================
                FORMULARIO REPARACION
    ====================================== -->

    <record id="view_joyeria_reparacion_form" model="ir.ui.view">
        <field name="name">joyeria.reparacion.form</field>
        <field name="model">joyeria.reparacion</field>

        <field name="arch" type="xml">

            <form string="Orden de Reparación">

               <sheet>

    <group col="2">

        <!-- INFORMACIÓN GENERAL -->

        <group string="Información General" col="2">

            <field name="name" readonly="1"/>
            <field name="cliente_id"/>

            <field name="tipo_cliente"/>
            <field name="correo_cliente"/>

            <field name="telefono"/>
            <field name="direccion_entrega"/>

            <field name="responsable_id"
                   groups="base.group_system"/>

            <field name="qr"
                   widget="image"
                   class="oe_avatar"
                   readonly="1"/>

        </group>


        <!-- PRODUCTO Y SERVICIO -->

        <group string="Producto y Servicio" col="2">

            <field name="servicio"/>

            <field name="tipo_joya"
                   visibility_condition="servicio == 'reparacion'"/>

            <field name="modelo"/>
            <field name="cantidad"/>

            <field name="metal"/>
            <field name="peso"/>

            <field name="n_cm_reparacion"
                   visibility_condition="servicio == 'reparacion'"/>

            <field name="n_cm_fabricacion"
                   visibility_condition="servicio == 'fabricacion'"/>

            <field name="peso_valor"/>

            <newline/>

            <field name="solicitud_cliente"
                   colspan="2"/>

        </group>


                        <!-- SALIDA DEL TALLER -->

                      <!-- ======================================
                            CALCULADORA TALLER
                    ====================================== -->

                    <group string="Calculadora Taller"
                        groups="base.group_system"
                        colspan="2">

                        <!-- FABRICACION -->

                        <group string="Fabricación"
                            col="2"
                            invisible="servicio != 'fabricacion'">

                            <field name="metal_utilizado"/>

                            <field name="tipo_diseno"/>

                            <field name="tipo_vector"/>

                            <field name="cantidad"/>

                            <field name="cantidad_circones"/>

                            <field name="cantidad_brillantes_manual"/>
                            <field name="valor_brillante_unitario"/>

                            <field name="cantidad_moissanita_manual"/>
                            <field name="valor_moissanita_unitario"/>

                            <field name="rodinado_cantidad"/>
                            <field name="rodinado_valor"/>

                            <field name="otro_taller"/>

                        </group>


                        <!-- REPARACION -->

                         <group string="Reparación"
                            col="2"
                            invisible="servicio != 'reparacion'">

                            <field name="metal_utilizado"/>

                            <separator string="SOLDADURA" colspan="4"/>

                            <group col="4">

                                <div class="o_form_label">
                                    Cantidad
                                </div>

                                <field name="soldadura_cantidad" nolabel="1"/>

                                <div class="o_form_label">
                                    Valor
                                </div>

                                <field name="soldadura_valor" nolabel="1"/>

                            </group>

                            <separator string="Piedras"/>

                            <group col="2">
                                <field name="piedras_cantidad"/>
                                <field name="piedras_valor"/>
                            </group>

                            <separator string="Brillantes"/>

                            <group col="2">
                                <field name="cantidad_brillantes_manual"/>
                                <field name="valor_brillante_unitario"/>
                            </group>

                            <separator string="Moissanita"/>

                            <group col="2">
                                <field name="cantidad_moissanita_manual"/>
                                <field name="valor_moissanita_unitario"/>
                            </group>

                            <separator string="Rodinado / Baño"/>

                            <group col="2">
                                <field name="rodinado_bano_cantidad"/>
                                <field name="rodinado_bano_valor"/>
                            </group>

                            <separator string="Otro"/>

                            <field name="otro_reparacion"/>

                        </group>


                    <!-- RESUMEN -->

                    <group string="Resumen Taller"
                        groups="base.group_system"
                        col="2">

                        <field name="hechura"
                            readonly="1"/>

                        <field name="cobro_interno"
                            readonly="1"/>

                        <field name="cobros_extras"
                            readonly="1"/>

                        <field name="total_salida_taller"
                            readonly="1"
                            style="
                                    background-color:#fff8b3;
                                    color:#665c00;
                                    font-size:22px;
                                    font-weight:bold;
                            "/>

                        <field name="clave_firma_manual"
                            password="True"/>

                        <field name="firma_id"
                            readonly="1"/>

                        <field name="fecha_firma"
                            readonly="1"/>

                    </group>

                        <!-- RECEPCIÓN Y ENTREGA -->

                       <!-- ======================================
        RECEPCIÓN
====================================== -->

<group string="Recepción y Entrega"
       col="2">

    <field name="vendedora_id"
           readonly="1"
           options="{'no_open': True, 'no_create': True}"/>

    <field name="clave_autenticacion_manual"
           password="True"/>

    <field name="local_tienda"/>

    <field name="fecha_recepcion"
           readonly="1"/>

    <field name="fecha_entrega"/>

    <field name="estado"
           groups="base.group_system"/>

    <field name="express"/>

                    </group>


                    <!-- ======================================
                            FINANZAS
                    ====================================== -->

                    <group string="Datos Financieros"
                        col="2">

                        <field name="precio_unitario"
                            invisible="tipo_cliente in ['cliente mayorista','cliente preferente']"/>

                        <field name="hechura2"
                            invisible="tipo_cliente not in ['cliente mayorista','cliente preferente']"/>

                        <field name="extra"/>

                        <field name="descripcion_extra_1"
                            placeholder="Descripción 1"
                            invisible="tipo_cliente not in ['cliente mayorista','cliente preferente','cliente normal']"/>

                        <field name="extra2"/>

                        <field name="descripcion_extra_2"
                            placeholder="Descripción 2"
                            invisible="tipo_cliente not in ['cliente mayorista','cliente preferente','cliente normal']"/>

                        <field name="extra3"/>

                        <field name="descripcion_extra_3"
                            placeholder="Descripción 3"
                            invisible="tipo_cliente not in ['cliente mayorista','cliente preferente','cliente normal']"/>

                        <field name="subtotal"
                            readonly="1"/>

                        <field name="abono"/>

                        <field name="saldo"
                            readonly="1"/>

                    </group>
                </group>

                     </group>

                    <!-- AUTORIZACIÓN -->

                    <field name="requiere_autorizacion"
                        invisible="1"/>

                    <group string="Autorización (solo si es sin costo)"
                        invisible="not requiere_autorizacion">

                        <field name="codigo_ingresado"
                            force_save="1"
                            placeholder="Ingresa el código entregado por administración"/>

                    </group>


                    <!-- NOTAS -->

                    <group string="Notas y Comentarios"
                           col="2">

                        <field name="notas"/>

                        <field name="comentarios"/>

                    </group>


                    <!-- OPERACIONES -->

                    <notebook>

                        <page string="Operaciones">

                            <field name="lineas_operacion_ids">

                                <tree editable="bottom">

                                    <field name="producto_id"/>
                                    <field name="descripcion"/>
                                    <field name="cantidad"/>
                                    <field name="unidad_medida"/>
                                    <field name="precio_unitario"/>

                                </tree>

                            </field>

                        </page>

                    </notebook>


                    <!-- CHATTER -->

                    <div class="oe_chatter">

                        <field name="message_follower_ids"
                               widget="mail_followers"/>

                        <field name="message_ids"
                               widget="mail_thread"/>

                    </div>

                </sheet>

            </form>

        </field>

    </record>


    <!-- ======================================
                    TREE VIEW
    ====================================== -->

    <!-- Vista árbol -->
    <record id="view_custom_repair_order_tree" model="ir.ui.view">
        <field name="name">custom.repair.order.tree</field>
        <field name="model">joyeria.reparacion</field>
        <field name="arch" type="xml">
            <tree string="Órdenes de Reparación" create="1"
                  decoration-info="estado == 'presupuesto'"
                  decoration-success="estado == 'confirmado'"
                  decoration-primary="estado == 'reparado'"
                  decoration-danger="estado == 'reparado y entregado'">
                <field name="name" type="open"/>
                <field name="tipo_joya"/>
                <field name="cliente_id"/>
                <field name="direccion_entrega"/>
                <field name="vencimiento_garantia"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>



    <!-- Acción y Menú -->
    <record id="action_joyeria_reparacion_listado" model="ir.actions.act_window">
        <field name="name">Órdenes de Reparación</field>
        <field name="res_model">joyeria.reparacion</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_joyeria_reparacion" model="ir.actions.act_window">
        <field name="name">Reparaciones</field>
        <field name="res_model">joyeria.reparacion</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_joyeria_reparacion_form"/>
    </record>

    <menuitem id="menu_joyeria_root"
              name="Reparaciones"
              action="action_joyeria_reparacion_listado"/>
</odoo>