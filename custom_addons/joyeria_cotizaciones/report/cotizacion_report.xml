<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_cotizacion" model="ir.actions.report">

        <field name="name">Cotización</field>

        <field name="model">joyeria.cotizacion</field>

        <field name="report_type">qweb-pdf</field>

        <field name="report_name">
            joyeria_cotizaciones.report_cotizacion_template
        </field>

        <field name="report_file">
            joyeria_cotizaciones.report_cotizacion_template
        </field>

        <field name="print_report_name">
            'Cotizacion - %s' % (object.name)
        </field>

    </record>

</odoo>